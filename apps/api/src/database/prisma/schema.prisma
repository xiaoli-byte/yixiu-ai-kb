// Prisma schema - 用于类型生成，业务表结构由 init.sql 管理
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pg_trgm, pgcrypto, uuidOssp(map: "uuid-ossp")]
}

// 注：prisma db push 仅用于本地开发，结构与 init.sql 保持一致

model User {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  email        String
  name         String
  passwordHash String   @map("password_hash")
  role         String   @default("viewer")
  departmentId String?  @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  documents       Document[]       @relation("Owner")
  conversations   QAConversation[]

  @@unique([tenantId, email])
  @@map("users")
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("departments")
}

model Folder {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, name, parentId])
  @@map("folders")
}

model Document {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  ownerId      String   @map("owner_id")
  folderId     String?  @map("folder_id")
  title        String
  mime         String
  size         BigInt   @default(0)
  status       String   @default("PENDING")
  storageKey   String   @map("storage_key")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  owner User           @relation("Owner", fields: [ownerId], references: [id])
  tags  DocumentTag[]
  chunks Chunk[]

  @@index([tenantId])
  @@index([status])
  @@map("documents")
}

model Chunk {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  idx        Int
  text       String
  tokens     Int      @default(0)
  page       Int?     // PDF 页码（1-based）
  embedding  Unsupported("vector(1024)")
  tsvZh      Unsupported("tsvector") @map("tsv_zh") // 中文全文检索（zhparser）
  tsvSimple  Unsupported("tsvector") @map("tsv_simple") // 英文/通用全文检索
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, idx])
  @@map("chunks")
}

model Tag {
  id   String @id @default(cuid())
  name String
  type String @default("MANUAL")

  documents DocumentTag[]

  @@unique([name, type])
  @@map("tags")
}

model DocumentTag {
  documentId String @map("document_id")
  tagId      String @map("tag_id")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@map("document_tags")
}

model QAConversation {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  title     String   @default("新会话")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages QAMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("qa_conversations")
}

model QAMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  role           String
  content        String
  citations      Json?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation QAConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("qa_messages")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}
