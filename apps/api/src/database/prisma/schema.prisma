// Prisma schema 是 PostgreSQL 业务表结构的唯一声明来源。
// 所有结构变更必须先修改本文件，再通过 Prisma Migrate 生成/部署迁移。
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pg_trgm, pgcrypto, uuidOssp(map: "uuid-ossp")]
}

// 禁止使用 prisma db push 修改业务表结构；开发请使用 prisma migrate dev，部署请使用 prisma migrate deploy。

model User {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  email        String
  name         String
  passwordHash String   @map("password_hash")
  role         String   @default("viewer")
  departmentId String?  @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  documents       Document[]       @relation("Owner")
  conversations   QAConversation[]

  @@unique([tenantId, email])
  @@map("users")
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("departments")
}

model Folder {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, name, parentId])
  @@map("folders")
}

model Document {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  ownerId      String   @map("owner_id")
  folderId     String?  @map("folder_id")
  contentId    String?  @map("content_id")
  fileHash     String?  @map("file_hash")
  contentHash  String?  @map("content_hash")
  duplicateOfDocumentId String? @map("duplicate_of_document_id")
  dedupReason  String?  @map("dedup_reason")
  title        String
  mime         String
  size         BigInt   @default(0)
  status       String   @default("PENDING")
  storageKey   String   @map("storage_key")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  owner User           @relation("Owner", fields: [ownerId], references: [id])
  content DocumentContent? @relation(fields: [contentId], references: [id], onDelete: SetNull)
  tags  DocumentTag[]
  chunks Chunk[]
  structuredFacts StructuredFact[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status], map: "documents_tenant_status_idx")
  @@index([ownerId], map: "documents_owner_idx")
  @@index([contentId])
  @@index([tenantId, fileHash])
  @@index([tenantId, contentHash])
  @@map("documents")
}

model DocumentContent {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  contentHash         String   @map("content_hash")
  firstFileHash       String?  @map("first_file_hash")
  title               String
  mime                String
  size                BigInt   @default(0)
  status              String   @default("PENDING")
  storageKey          String?  @map("storage_key")
  canonicalDocumentId String?  @map("canonical_document_id")
  chunkCount          Int      @default(0) @map("chunk_count")
  duplicateCount      Int      @default(1) @map("duplicate_count")
  sourceCount         Int      @default(1) @map("source_count")
  errorMessage        String?  @map("error_message")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  uploads Document[]
  chunks Chunk[]
  structuredFacts StructuredFact[]
  edgeEvidences EdgeEvidence[]

  @@unique([tenantId, contentHash])
  @@index([tenantId, status])
  @@map("document_contents")
}

model Chunk {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  contentId  String?  @map("content_id")
  chunkHash  String?  @map("chunk_hash")
  idx        Int
  text       String
  tokens     Int      @default(0)
  page       Int?     // PDF 页码（1-based）
  embedding  Unsupported("vector(1024)")
  tsvZh      Unsupported("tsvector") @map("tsv_zh") // 中文全文检索（zhparser）
  tsvSimple  Unsupported("tsvector") @map("tsv_simple") // 英文/通用全文检索
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content DocumentContent? @relation(fields: [contentId], references: [id], onDelete: Cascade)
  structuredFacts StructuredFact[]

  @@index([documentId, idx])
  @@index([contentId, idx])
  @@index([chunkHash])
  @@unique([contentId, idx], map: "chunks_content_idx_unique")
  @@map("chunks")
}

model Tag {
  id   String @id @default(cuid())
  name String
  type String @default("MANUAL")

  documents DocumentTag[]

  @@unique([name, type])
  @@map("tags")
}

model DocumentTag {
  documentId String @map("document_id")
  tagId      String @map("tag_id")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@map("document_tags")
}

model QAConversation {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  title     String   @default("新会话")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages QAMessage[]
  runLogs  QARunLog[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("qa_conversations")
}

model QAMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  role           String
  content        String
  citations      Json?
  feedbackRating String?  @map("feedback_rating") @db.VarChar(20)
  feedbackText   String?  @map("feedback_text")
  feedbackAt     DateTime? @map("feedback_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at")

  conversation QAConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([feedbackRating], map: "qa_messages_feedback_rating_idx")
  @@map("qa_messages")
}

model SearchHistory {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  userId      String   @map("user_id")
  query       String
  mode        String   @default("hybrid") @db.VarChar(30)
  sortBy      String   @default("relevance") @map("sort_by") @db.VarChar(30)
  topK        Int      @default(10) @map("top_k")
  resultCount Int      @default(0) @map("result_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, userId, createdAt(sort: Desc)], map: "search_histories_tenant_user_created_idx")
  @@index([tenantId, userId, query], map: "search_histories_tenant_user_query_idx")
  @@map("search_histories")
}

model StructuredFact {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  documentId  String   @map("document_id")
  contentId   String?  @map("content_id")
  chunkId     String?  @map("chunk_id")
  factHash    String?  @map("fact_hash")
  domain      String
  entityType  String   @map("entity_type")
  entityName  String   @map("entity_name")
  attributes  Json     @default("{}")
  confidence  Float    @default(0.5)
  sourceText  String   @map("source_text")
  createdAt   DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content  DocumentContent? @relation(fields: [contentId], references: [id], onDelete: Cascade)
  chunk    Chunk?   @relation(fields: [chunkId], references: [id], onDelete: SetNull)

  @@index([tenantId, domain, entityType])
  @@index([documentId])
  @@index([contentId])
  @@index([factHash])
  @@unique([tenantId, contentId, factHash], map: "structured_facts_content_fact_unique")
  @@map("structured_facts")
}

model KnowledgeNode {
  id           String   @id
  tenantId     String   @map("tenant_id")
  canonicalKey String   @map("canonical_key")
  name         String
  type         String
  aliases      Json     @default("[]")
  mergeStatus  String   @default("ACTIVE") @map("merge_status")
  mergedIntoNodeId String? @map("merged_into_node_id")
  mergedBy     String?  @map("merged_by")
  mergedReason String?  @map("merged_reason")
  mergedAt     DateTime? @map("merged_at")
  sourceCount  Int      @default(0) @map("source_count")
  mentionCount Int      @default(0) @map("mention_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  outgoingEdges KnowledgeEdge[] @relation("KnowledgeEdgeSource")
  incomingEdges KnowledgeEdge[] @relation("KnowledgeEdgeTarget")
  changes       KnowledgeGraphChange[] @relation("KnowledgeGraphChangeNode")

  @@unique([tenantId, canonicalKey])
  @@index([tenantId, type])
  @@index([tenantId, mergeStatus])
  @@map("knowledge_nodes")
}

model KnowledgeEdge {
  id           String   @id
  tenantId     String   @map("tenant_id")
  sourceNodeId String   @map("source_node_id")
  targetNodeId String   @map("target_node_id")
  relationType String   @map("relation_type")
  edgeKey      String   @map("edge_key")
  weight       Int      @default(1)
  evidenceCount Int    @default(0) @map("evidence_count")
  sourceCount   Int    @default(0) @map("source_count")
  status       String   @default("ACTIVE")
  reviewStatus String   @default("APPROVED") @map("review_status")
  sourceType   String   @default("AI") @map("source_type")
  editedBy     String?  @map("edited_by")
  editedReason String?  @map("edited_reason")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sourceNode KnowledgeNode @relation("KnowledgeEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode KnowledgeNode @relation("KnowledgeEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  evidences  EdgeEvidence[]
  changes    KnowledgeGraphChange[] @relation("KnowledgeGraphChangeEdge")

  @@unique([tenantId, edgeKey])
  @@index([tenantId, relationType])
  @@index([tenantId, status, reviewStatus])
  @@map("knowledge_edges")
}

model EdgeEvidence {
  id                String   @id
  tenantId          String   @map("tenant_id")
  edgeId            String   @map("edge_id")
  documentContentId String   @map("document_content_id")
  documentId        String?  @map("document_id")
  chunkId           String?  @map("chunk_id")
  evidenceHash      String   @map("evidence_hash")
  evidenceText      String?  @map("evidence_text")
  confidence        Float?
  sourceType        String   @default("AI") @map("source_type")
  createdAt         DateTime @default(now()) @map("created_at")

  edge    KnowledgeEdge @relation(fields: [edgeId], references: [id], onDelete: Cascade)
  content DocumentContent @relation(fields: [documentContentId], references: [id], onDelete: Cascade)

  @@index([edgeId, documentContentId])
  @@index([tenantId, documentContentId])
  @@index([chunkId])
  @@map("edge_evidences")
}

model KnowledgeGraphChange {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String?  @map("user_id")
  action    String
  nodeId    String?  @map("node_id")
  edgeId    String?  @map("edge_id")
  reason    String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now()) @map("created_at")

  node KnowledgeNode? @relation("KnowledgeGraphChangeNode", fields: [nodeId], references: [id], onDelete: SetNull)
  edge KnowledgeEdge? @relation("KnowledgeGraphChangeEdge", fields: [edgeId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([nodeId])
  @@index([edgeId])
  @@map("knowledge_graph_changes")
}

model KnowledgeGraphView {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  userId      String   @map("user_id")
  name        String
  description String?
  visibility  String   @default("PRIVATE")
  filters     Json     @default("{}")
  layout      Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId, userId])
  @@index([tenantId, visibility])
  @@map("knowledge_graph_views")
}

model QARunLog {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  userId         String?  @map("user_id")
  conversationId String?  @map("conversation_id")
  question       String
  rewrittenQuery String?  @map("rewritten_query")
  intent         String
  domain         String
  facts          Json     @default("[]")
  chunks         Json     @default("[]")
  toolResult     Json?    @map("tool_result")
  answer         String?
  error          String?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation QAConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("qa_run_logs")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}
