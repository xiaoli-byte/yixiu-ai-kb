{
  "name": "@ai-knowledge/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "worker:dev": "ts-node -r tsconfig-paths/register src/worker.ts",
    "build": "nest build",
    "start": "node dist/main.js",
    "worker": "node dist/worker.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "clean": "rm -rf dist .turbo",
    "prisma": "node scripts/prisma-root-env.cjs",
    "prisma:generate": "node scripts/prisma-root-env.cjs generate --schema src/database/prisma/schema.prisma",
    "prisma:migrate:dev": "node scripts/prisma-root-env.cjs migrate dev --schema src/database/prisma/schema.prisma",
    "prisma:migrate:deploy": "node scripts/prisma-root-env.cjs migrate deploy --schema src/database/prisma/schema.prisma",
    "prisma:migrate:status": "node scripts/prisma-root-env.cjs migrate status --schema src/database/prisma/schema.prisma",
    "prisma:studio": "node scripts/prisma-root-env.cjs studio --schema src/database/prisma/schema.prisma",
    "neo4j:migrate": "ts-node -r tsconfig-paths/register src/database/neo4j/migrate.ts",
    "check:dedup": "ts-node -r tsconfig-paths/register scripts/check-dedup-canonical.ts",
    "repair:dedup": "ts-node -r tsconfig-paths/register scripts/repair-content-dedup.ts",
    "seed": "ts-node -r tsconfig-paths/register src/seed/seed.ts"
  },
  "dependencies": {
    "@ai-knowledge/schemas": "workspace:*",
    "@ai-knowledge/tsconfig": "workspace:*",
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.2.0",
    "@langchain/textsplitters": "^1.0.1",
    "@napi-rs/canvas": "^1.0.0",
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.7",
    "@nestjs/serve-static": "^4.0.2",
    "@node-rs/jieba": "^2.0.1",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "bluebird": "^3.7.2",
    "bullmq": "^5.21.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "ioredis": "~5.10.1",
    "jszip": "^3.10.1",
    "langchain": "^1.5.0",
    "mammoth": "^1.8.0",
    "minio": "^8.0.1",
    "neo4j-driver": "^5.25.0",
    "nestjs-cls": "^4.4.1",
    "nestjs-pino": "^4.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^6.0.227",
    "pg": "^8.13.1",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.2",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.7",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
