# ============================================================
# AI Knowledge Base - Production Environment Configuration
# ============================================================
# 
# 使用说明:
#   1. 复制此文件为 .env.production
#   2. 修改所有密码和密钥为安全值
#   3. 配置域名和 SSL 证书 (如需要 HTTPS)
#   4. 运行部署脚本: ./deploy.sh
#
# 重要安全提醒:
#   - 所有密码和密钥必须修改为强密码
#   - DASHSCOPE_API_KEY 需要在阿里百炼平台申请
#   - 生产环境务必使用 HTTPS

# ===== 应用基础配置 =====
NODE_ENV=production
API_PORT=9999
WEB_PORT=8888
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
WEB_ORIGIN=https://your-domain.com
LOG_LEVEL=info
API_INTERNAL_URL=http://api:9999/api
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_DEMO_MODE=false
APP_TIME_ZONE=Asia/Shanghai

# ===== PostgreSQL =====
# 容器内部连接 (不需要修改)
POSTGRES_USER=ai_knowledge
POSTGRES_PASSWORD=CHANGE_ME_change_this_password_in_production
POSTGRES_DB=ai_knowledge
POSTGRES_PORT=55432
DATABASE_URL=postgresql://ai_knowledge:CHANGE_ME_change_this_password_in_production@postgres:5432/ai_knowledge

# ===== Redis =====
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ===== MinIO =====
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_change_this_password_in_production
MINIO_ENDPOINT=minio
MINIO_PUBLIC_URL=https://your-domain.com/minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=ai-knowledge-docs
S3_REGION=us-east-1
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=CHANGE_ME_change_this_password_in_production

# ===== Neo4j =====
NEO4J_URI=bolt://neo4j:7687
NEO4J_HTTP_URL=http://neo4j:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_change_this_password_in_production
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ===== 鉴权 =====
# JWT 密钥必须使用强随机字符串生成
# 推荐使用: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# 初始管理员账户
BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_use_strong_password
BOOTSTRAP_ADMIN_NAME=System Admin
BOOTSTRAP_TENANT_ID=tenant_default

# ===== 通义千问 DashScope =====
# 在阿里百炼平台申请: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_LLM_MODEL=qwen-plus
DASHSCOPE_EMBED_MODEL=text-embedding-v4
DASHSCOPE_EMBED_DIM=1024
DASHSCOPE_LLM_MOCK=false
DASHSCOPE_EMBED_MOCK=false

# ===== 检索参数 =====
SEARCH_BM25_TOPK=50
SEARCH_VECTOR_TOPK=50
SEARCH_RRF_K=60
SEARCH_RRF_FINAL_TOPK=10
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBED_BATCH_SIZE=10

# ===== 多模态解析 =====
FUNASR_HTTP_URL=http://host.docker.internal:10095
FUNASR_TIMEOUT_MS=600000
PADDLEOCR_HTTP_URL=http://host.docker.internal:10096/ocr
PADDLEOCR_PORT=10096
PADDLEOCR_LANG=ch
PADDLEOCR_UPLOAD_FIELD=image
PADDLEOCR_LANG_FIELD=lang
PADDLEOCR_TIMEOUT_MS=600000
PADDLEOCR_USE_ANGLE_CLS=true
OCR_PDF_RENDER_SCALE=2
OCR_PDF_MAX_PAGES=0
DOCUMENT_UPLOAD_MAX_MB=100

# ===== 文档队列 Worker =====
# 生产 Docker Compose 会将 API 服务覆盖为 DOCUMENT_WORKER_ENABLED=false，
# 独立 worker 服务使用 true 消费队列。
DOCUMENT_WORKER_ENABLED=true
DOCUMENT_WORKER_CONCURRENCY=1
