# ===== 应用基础配置 =====
# 只在仓库根目录维护 .env / .env.local；不要在 apps/* 下创建额外 .env。
NODE_ENV=development
API_PORT=9999
WEB_PORT=8888
WEB_ORIGIN=http://localhost:8888
LOG_LEVEL=info
API_INTERNAL_URL=http://127.0.0.1:9999/api
NEXT_PUBLIC_API_URL=/api

# ===== 作为 ai-call 知识库微前端（Multi-Zones）内嵌运行时（可选）=====
# 设置后所有页面与 /_next 资源挂到该前缀下，供 ai-call 同域内嵌；不设则 8888 根路径独立访问照旧。
# 同时需把上面的 NEXT_PUBLIC_API_URL 改成 /knowledge/api（构建期变量，改后需重建），
# 由网关将 /knowledge/api/* 分流到本项目 API。详见 ai-call 仓 docs/knowledge-base-microfrontend.md。
# WEB_BASE_PATH=/knowledge
# 登录页演示模式：true 时预填演示账号密码；false 时不预填
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEMO_EMAIL=admin@demo.com
NEXT_PUBLIC_DEMO_PASSWORD=demo123
# 用于 AI 问答中的"现在/今天/今年/距离现在"等时间计算
APP_TIME_ZONE=Asia/Shanghai

# ===== PostgreSQL =====
# 应用层连接 URL 必须与 POSTGRES_PORT 保持一致
# 数据库用户名
POSTGRES_USER=ai_knowledge
# 数据库密码
POSTGRES_PASSWORD=dev_password
# 数据库名称
POSTGRES_DB=ai_knowledge
# 端口选择：避免 5432 被其他项目占用，也避开部分 Windows 环境保留的 55432
POSTGRES_PORT=56432
DATABASE_URL=postgresql://ai_knowledge:dev_password@localhost:56432/ai_knowledge

# ===== Redis =====
# 避免被占用，docker 暴露到 6399
REDIS_PORT=6399
REDIS_URL=redis://localhost:6399

# ===== MinIO =====
# 避免被占用，docker 暴露到 9100
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_PORT=9100
MINIO_CONSOLE_PORT=9101
MINIO_ENDPOINT=localhost
MINIO_PUBLIC_URL=http://localhost:9100
S3_BUCKET=ai-knowledge-docs
S3_REGION=us-east-1
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_password

# ===== Neo4j =====
NEO4J_URI=bolt://localhost:7687
NEO4J_HTTP_URL=http://localhost:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev_password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ===== 鉴权 =====
JWT_ACCESS_SECRET=dev_access_secret_change_me_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_in_production
# 开发可维持 HS256；生产启动会强制 RS256。PEM 可写为单行并使用 \n 转义。
JWT_ACCESS_ALGORITHM=HS256
JWT_ACCESS_PRIVATE_KEY=
JWT_ACCESS_PUBLIC_KEY=
JWT_ACCESS_KEY_ID=ai-knowledge-v1
# ai-call 的 RS256 公钥；联合登录 token 必须携带 kid=ai-call-v1。
FEDERATED_JWT_ACCESS_PUBLIC_KEY=
FEDERATED_JWT_ACCESS_KEY_ID=ai-call-v1
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BOOTSTRAP_ADMIN_EMAIL=admin@demo.com
BOOTSTRAP_ADMIN_PASSWORD=demo123
BOOTSTRAP_ADMIN_NAME=Demo Admin
BOOTSTRAP_TENANT_ID=tenant_demo

# ===== 服务间调用认证 (KB-08) =====
# 用于保护服务间 API 端点（如 ai-call → ai-knowledge 的 /search/retrieve）
# 生产环境必须配置；开发环境未配置时放行但仍强制租户隔离
SERVICE_API_TOKEN=dev_service_token_change_me_in_production
# 可选：是否要求时间戳签名（额外防重放）
SERVICE_API_REQUIRE_SIGNATURE=false
# 可选：签名密钥（默认回退到 SERVICE_API_TOKEN）
# SERVICE_API_SIGNING_SECRET=
# 可选：签名时间容差（毫秒，默认 300000 = 5 分钟）
# SERVICE_API_SIGNATURE_TOLERANCE_MS=300000

# ===== 联合登录 (CALL-13) =====
# 可选：逗号分隔的租户 id 白名单，限制哪些租户的联合身份（ai-call cookie）允许 JIT 开通；
# 不设 = 不额外限制（租户仍必须已存在于本库 tenants 表且 active）
# FEDERATED_TENANT_ALLOWLIST=tenant_demo

# ===== 通义千问 DashScope =====
#填写你的通义千问 DashScope API Key，在阿里百炼平台申请
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_LLM_MODEL=qwen-plus
DASHSCOPE_EMBED_MODEL=text-embedding-v4
DASHSCOPE_EMBED_DIM=1024
DASHSCOPE_LLM_MOCK=false
DASHSCOPE_EMBED_MOCK=false
# QA 检索重排模型（可选，默认 gte-rerank-v2；DASHSCOPE_RERANK_MOCK=true 时保持召回原序）
DASHSCOPE_RERANK_MODEL=gte-rerank-v2
DASHSCOPE_RERANK_MOCK=false

# ===== 检索参数 =====
SEARCH_BM25_TOPK=50
SEARCH_VECTOR_TOPK=50
SEARCH_RRF_K=60
SEARCH_RRF_FINAL_TOPK=10
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBED_BATCH_SIZE=10

# ===== 多模态解析 =====
# FunASR HTTP 服务地址，用于音频/音视频文件 ASR 转写后再切片向量化
FUNASR_HTTP_URL=http://localhost:10095
FUNASR_TIMEOUT_MS=600000
# PaddleOCR HTTP 服务地址，用于图片和扫描 PDF OCR 后再切片向量化
PADDLEOCR_HTTP_URL=http://localhost:10096/ocr
PADDLEOCR_PORT=10096
PADDLEOCR_LANG=ch
PADDLEOCR_UPLOAD_FIELD=image
PADDLEOCR_LANG_FIELD=lang
PADDLEOCR_TIMEOUT_MS=600000
PADDLEOCR_USE_ANGLE_CLS=true
OCR_PDF_RENDER_SCALE=2
OCR_PDF_MAX_PAGES=0
DOCUMENT_UPLOAD_MAX_MB=100

# ===== 文档队列 Worker =====
# 开发时建议 API 和文档处理 Worker 分开跑，避免上传向量化时阻塞页面接口
DOCUMENT_WORKER_ENABLED=true
DOCUMENT_WORKER_CONCURRENCY=1
