shamefully-hoist=true
confirmModulesPurge=false
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=*next*

# GitHub Packages — publishing @xiaoli-byte/authz (see docs/authz-implementation-backlog.md AUTHZ-07).
# Requires GITHUB_TOKEN in the environment (a PAT with write:packages); never hardcode the token here.
@xiaoli-byte:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
